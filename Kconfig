config FLB36_STATUS_SCREEN
    bool "FLB36 dongle status screen"
    depends on ZMK_DISPLAY
    default n
    help
      Show both split-peripheral battery levels and the active host profile.

config FLB36_I2C_TEST
    bool "FLB36 raw OLED diagnostic"
    default n
    help
      Write a checkerboard directly to SSD1306 display RAM.
