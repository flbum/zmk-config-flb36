config FLB36_STATUS_SCREEN
    bool "FLB36 raw-I2C dongle status screen"
    default n
    help
      Show both peripheral battery levels and the active host profile.

config FLB36_CHARGE_STATUS
    bool "FLB36 peripheral USB-power reporting"
    default n
    depends on BT_BAS
    help
      Include USB-power state in the battery value sent to the dongle.

config FLB36_RGB_PROXY
    bool "FLB36 split underglow proxy"
    default n
    help
      Expose underglow controls to Studio on the dongle and forward them to both halves.

config FLB36_I2C_TEST
    bool "FLB36 raw OLED diagnostic"
    default n
    help
      Write a checkerboard directly to SSD1306 display RAM.
